    <!-- JavaScript -->
    <script>
        document.getElementById('ownerHistoryForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const vehicleNumber = document.getElementById('vehicleNumber').value;
            const loadingSpinner = document.getElementById('loadingSpinner');
            const resultsDiv = document.getElementById('ownerHistoryResults');
            
            loadingSpinner.style.display = 'block';
            resultsDiv.innerHTML = '';
            
            try {
                const response = await fetch(`/api/vehicles/owner-history?vehicleId=${vehicleNumber}`);
                const result = await response.json();
                
                if (result.success) {
                    displayOwnerHistory(result.data);
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-danger">
                            <strong>Error:</strong> ${result.error || 'Vehicle history not found. Please check the vehicle number and try again.'}
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error:', error);
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <strong>Error:</strong> Failed to fetch vehicle history. Please try again.
                    </div>
                `;
            }
            
            loadingSpinner.style.display = 'none';
        });
        
        function displayOwnerHistory(data) {
            const resultsDiv = document.getElementById('ownerHistoryResults');
            
            resultsDiv.innerHTML = `
                <div class="card">
                    <h3>📋 Vehicle Owner History</h3>
                    <div class="grid">
                        <div>
                            <h4>👤 Owner Details</h4>
                            <p><strong>Owner Name:</strong> ${data.ownerName}</p>
                            <p><strong>Vehicle Number:</strong> ${data.vehicleId}</p>
                        </div>
                        <div>
                            <h4>🏭 Vehicle Details</h4>
                            <p><strong>Make:</strong> ${data.vehicleInfo.make}</p>
                            <p><strong>Model:</strong> ${data.vehicleInfo.model}</p>
                            <p><strong>Manufacturing Year:</strong> ${data.vehicleInfo.manufacturingYear}</p>
                            <p><strong>Vehicle Type:</strong> ${data.vehicleInfo.vehicleType}</p>
                            <p><strong>Fuel Type:</strong> ${data.vehicleInfo.fuelType}</p>
                            <p><strong>Color:</strong> ${data.vehicleInfo.color}</p>
                        </div>
                        <div>
                            <h4>📋 Registration Information</h4>
                            <p><strong>Registration State:</strong> ${data.registrationDetails.state}</p>
                            <p><strong>Registration Expiry:</strong> ${data.registrationDetails.expiryDate}</p>
                        </div>
                        <div>
                            <h4>🛡️ Insurance Information</h4>
                            <p><strong>Insurance Expiry:</strong> ${data.insuranceDetails.expiryDate}</p>
                        </div>
                        <div>
                            <h4>🔧 Technical Details</h4>
                            <p><strong>Engine Number:</strong> ${data.technicalDetails.engineNumber}</p>
                            <p><strong>Chassis Number:</strong> ${data.technicalDetails.chassisNumber}</p>
                        </div>
                    </div>
                </div>
            `;
        }
    </script>
